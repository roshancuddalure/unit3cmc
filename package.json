{
  "name": "unit-3-management-system",
  "version": "0.1.0",
  "private": true,
  "description": "Unit 3 Anaesthesia management platform for logbooks, learning, SOPs, and unit operations.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run build && node dist/server.js",
    "dev:watch": "node --watch dist/server.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "playwright test",
    "db:migrate": "npm run build && node dist/scripts/migrate.js",
    "db:migrate:down": "node -e \"console.log('Down migrations are not automated in this local scaffold yet.')\"",
    "db:seed": "npm run build && node dist/scripts/seed.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.879.0",
    "@lumieducation/h5p-express": "^10.0.5",
    "@lumieducation/h5p-server": "^10.0.4",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.2.1",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "node-pg-migrate": "^8.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
