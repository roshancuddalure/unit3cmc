<%
  const pretty = (value) =>
    String(value || "")
      .split("_")
      .filter(Boolean)
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(" ");
  const showText = (value) => String(value ?? "").trim() || "-";
  const joinItems = (items) => (Array.isArray(items) && items.length ? items.join(", ") : "-");
  const caseLabel = (entry) => (entry.caseNumber ? `Case ${entry.caseNumber}` : "Case pending");
  const memberOptionLabel = (member) =>
    `${member.displayName}${member.designation ? ` | ${member.designation}` : ""} | @${member.username}`;
  const formatAdditionalMembers = (members) =>
    Array.isArray(members) && members.length
      ? members
          .map((member) => `${member.displayName}${member.designation ? ` (${member.designation})` : ""}`)
          .join(", ")
      : "-";
  const formatAsa = (value) => {
    const normalized = String(value || "").trim();
    if (!normalized) {
      return "-";
    }

    return normalized.startsWith("asa_")
      ? `ASA ${normalized.slice(4).toUpperCase()}`
      : normalized;
  };
%>
<%- include("../partials/header", { title, currentUser, flash }) %>

<section class="panel logbook-hero">
  <div class="logbook-hero-copy">
    <p class="eyebrow">Clinical logbook</p>
    <h1>De-identified anaesthesia case logging for every member of the unit</h1>
    <p class="section-copy">
      Record clinical work clearly, keep patient identity out of the system, and review your activity or unit trends when needed.
    </p>
    <div class="hero-actions">
      <button type="button" class="button-link" data-logbook-jump-tab="entries">Open case browser</button>
      <% if (canReview) { %>
        <button type="button" class="button-link button-link-secondary" data-logbook-jump-tab="oversight">Open chief/faculty browser</button>
      <% } %>
      <% if (canViewInvolvedCases) { %>
        <button type="button" class="button-link button-link-secondary" data-logbook-jump-tab="involved">Open cases involving me</button>
      <% } %>
    </div>
  </div>
  <div class="callout callout-info">
    <p class="section-kicker">Privacy</p>
    <p class="section-copy">
      Do not enter patient names, hospital numbers, full dates of birth, bed numbers, or any free text that can identify an individual patient. Use only de-identified clinical descriptors.
    </p>
  </div>
</section>

<section class="quick-stat-ribbon">
  <article class="quick-stat-chip">
    <span>Cases this period</span>
    <strong><%= personal.summary.totalCases %></strong>
  </article>
  <article class="quick-stat-chip">
    <span>Direct care</span>
    <strong><%= personal.summary.directCareCases %></strong>
  </article>
  <article class="quick-stat-chip">
    <span>Domains covered</span>
    <strong><%= personal.summary.domainCoverage %></strong>
  </article>
  <article class="quick-stat-chip">
    <span>Flagged events</span>
    <strong><%= personal.summary.complicationCount %></strong>
  </article>
</section>

<section class="panel logbook-tab-shell" data-logbook-tabs>
  <div class="section-header">
    <div>
      <p class="section-kicker">Sections</p>
      <h2>Choose what you want to view</h2>
    </div>
  </div>

  <nav class="logbook-tab-nav" aria-label="Logbook sections">
    <button type="button" class="button-link" data-logbook-tab="capture">
      <span>Capture case</span>
      <span class="tab-badge"><%= tabBadges.capture %></span>
    </button>
    <button type="button" class="button-link" data-logbook-tab="analysis">
      <span>My analysis</span>
      <span class="tab-badge"><%= tabBadges.analysis %></span>
    </button>
    <button type="button" class="button-link" data-logbook-tab="entries">
      <span>Case browser</span>
      <span class="tab-badge"><%= tabBadges.entries %></span>
    </button>
    <% if (canReview) { %>
      <button type="button" class="button-link" data-logbook-tab="oversight">
        <span>Unit oversight</span>
        <span class="tab-badge"><%= tabBadges.oversight %></span>
      </button>
    <% } %>
    <% if (canViewInvolvedCases) { %>
      <button type="button" class="button-link" data-logbook-tab="involved">
        <span>Cases involving me</span>
        <span class="tab-badge"><%= tabBadges.involved %></span>
      </button>
    <% } %>
  </nav>

  <section class="logbook-tab-panel" data-logbook-panel="capture">
    <div class="section-header">
      <div>
        <p class="section-kicker">Capture case</p>
        <h2>Structured perioperative logbook entry</h2>
      </div>
    </div>
    <p class="helper-text">The capture flow now follows the Unit 3 blueprint closely while still staying de-identified and review-ready.</p>
    <form action="/logbook" method="post" class="stack-form logbook-entry-form" data-logbook-blueprint-form>
      <datalist id="surgery-name-suggestions">
        <% surgeryNameSuggestions.forEach((item) => { %>
          <option value="<%= item %>"></option>
        <% }) %>
      </datalist>
      <datalist id="unit-member-suggestions">
        <% availableAdditionalMembers.forEach((member) => { %>
          <option value="<%= memberOptionLabel(member) %>" data-member-id="<%= member.id %>"></option>
        <% }) %>
      </datalist>

      <div class="callout compact-callout">
        <p class="section-kicker">Blueprint notes</p>
        <p class="section-copy">
          Each saved entry gets a user-specific case number automatically. The anaesthesia unit is fixed to Unit 3 for now, and surgery names stay free text with suggestions from previously logged cases.
        </p>
      </div>

      <fieldset class="form-section-card">
        <legend>Case overview</legend>
        <div class="fieldset-body">
          <div class="logbook-form-grid">
            <label><span>Date</span><input type="date" name="activityDate" required value="<%= personal.range.end %>" /></label>
            <label>
              <span>Case type</span>
              <select name="caseType" required>
                <% entryOptions.caseTypes.forEach((option) => { %>
                  <option value="<%= option %>"><%= option %></option>
                <% }) %>
              </select>
            </label>
            <label>
              <span>Anaesthesia unit</span>
              <input type="text" value="<%= entryOptions.fixedAnaesthesiaUnit %>" readonly />
            </label>
            <label><span>OT number</span><input type="text" name="otNumber" placeholder="OT-5" /></label>
            <label>
              <span>Surgical department</span>
              <select name="surgicalDepartment" required>
                <option value="">Choose department</option>
                <% entryOptions.surgicalDepartments.forEach((option) => { %>
                  <option value="<%= option %>"><%= option %></option>
                <% }) %>
              </select>
            </label>
            <label>
              <span>Surgery name</span>
              <input type="text" name="surgeryName" list="surgery-name-suggestions" placeholder="Start typing to see recent suggestions" required />
            </label>
          </div>
        </div>
      </fieldset>

      <fieldset class="form-section-card">
        <legend>Timing and demographics</legend>
        <div class="fieldset-body">
          <div class="logbook-form-grid">
            <label><span>Starting time</span><input type="time" name="surgeryStartTime" required data-logbook-start-time /></label>
            <label><span>Ending time</span><input type="time" name="surgeryEndTime" required data-logbook-end-time /></label>
            <div class="inline-helper-card">
              <strong>Duration</strong>
              <p class="meta-text" data-logbook-duration-label>Auto-calculated when start and end time are entered.</p>
            </div>
            <label><span>Age (years)</span><input type="number" name="ageYears" min="0" max="120" step="1" required /></label>
            <label>
              <span>Gender</span>
              <select name="gender" required>
                <option value="">Choose gender</option>
                <% entryOptions.genders.forEach((option) => { %>
                  <option value="<%= option %>"><%= option %></option>
                <% }) %>
              </select>
            </label>
            <label>
              <span>ASA physical status</span>
              <select name="asaPhysicalStatus" required>
                <option value="">Choose ASA</option>
                <% entryOptions.asaPhysicalStatuses.forEach((option) => { %>
                  <option value="<%= option %>"><%= option %></option>
                <% }) %>
              </select>
            </label>
            <label><span>BMI</span><input type="number" name="bmi" min="0" max="100" step="0.1" placeholder="24.6" /></label>
          </div>

          <div class="checkbox-section">
            <p class="section-kicker">Comorbidities</p>
            <div class="checkbox-grid">
              <% entryOptions.comorbidities.forEach((option) => { %>
                <label class="checkbox-card">
                  <input
                    type="checkbox"
                    name="comorbidities"
                    value="<%= option %>"
                    <%= option === "Others - Specify" ? "data-logbook-other-comorbidity-toggle" : "" %>
                  />
                  <span><%= option %></span>
                </label>
              <% }) %>
            </div>
            <label data-logbook-other-comorbidity-row hidden>
              <span>Other comorbidity details</span>
              <input type="text" name="otherComorbidity" placeholder="Only if Others - Specify is selected" />
            </label>
          </div>
        </div>
      </fieldset>

      <fieldset class="form-section-card">
        <legend>Anaesthesia and procedures</legend>
        <div class="fieldset-body">
          <div class="logbook-form-grid">
            <label>
              <span>Supervision level</span>
              <select name="supervisionLevel" required>
                <option value="">Choose supervision</option>
                <% entryOptions.supervisionLevels.forEach((option) => { %>
                  <option value="<%= option %>"><%= option %></option>
                <% }) %>
              </select>
            </label>
            <label>
              <span>Anaesthetic planned</span>
              <select name="anaestheticPlanned" required data-logbook-anaesthetic-plan>
                <option value="">Choose plan</option>
                <% entryOptions.anaestheticPlans.forEach((option) => { %>
                  <option value="<%= option %>"><%= option %></option>
                <% }) %>
              </select>
            </label>
            <label data-logbook-airway-wrapper hidden>
              <span>Airway management if GA</span>
              <select name="airwayManagement" data-logbook-airway-select>
                <option value="">Choose airway management</option>
                <% entryOptions.airwayManagements.forEach((option) => { %>
                  <option value="<%= option %>"><%= option %></option>
                <% }) %>
              </select>
            </label>
            <label data-logbook-scopy-wrapper hidden>
              <span>Scopy technique if ETT</span>
              <select name="scopyTechnique" data-logbook-scopy-select>
                <option value="">Choose technique</option>
                <% entryOptions.scopyTechniques.forEach((option) => { %>
                  <option value="<%= option %>"><%= option %></option>
                <% }) %>
              </select>
            </label>
          </div>

          <div class="checkbox-section">
            <p class="section-kicker">Procedures</p>
            <div class="checkbox-grid">
              <% entryOptions.procedures.forEach((option) => { %>
                <label class="checkbox-card">
                  <input type="checkbox" name="procedures" value="<%= option %>" />
                  <span><%= option %></span>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
      </fieldset>

      <fieldset class="form-section-card">
        <legend>Additional unit members</legend>
        <div class="fieldset-body">
          <div class="callout callout-info compact-callout">
            <p class="section-copy">
              Add zero or more registered active Unit 3 members who should also be able to open this case log later. The primary uploader remains the case owner.
            </p>
          </div>

          <div class="repeatable-shell" data-additional-member-root>
            <div class="repeatable-shell-head">
              <p class="section-kicker">Shared access members</p>
              <button type="button" class="button-link button-link-secondary" data-additional-member-add>Add member</button>
            </div>
            <div class="repeatable-list member-repeatable-list" data-additional-member-list></div>
            <p class="meta-text repeatable-empty-state" data-additional-member-empty>
              No additional members linked yet. This is optional, so you can leave it empty.
            </p>
          </div>
        </div>
      </fieldset>

      <fieldset class="form-section-card">
        <legend>Analgesia and outcome</legend>
        <div class="fieldset-body">
          <div class="checkbox-section">
            <p class="section-kicker">Analgesia</p>
            <div class="checkbox-grid">
              <% entryOptions.fixedAnalgesiaOptions.forEach((option) => { %>
                <label class="checkbox-card">
                  <input type="checkbox" name="analgesiaOptions" value="<%= option %>" />
                  <span><%= option %></span>
                </label>
              <% }) %>
            </div>
          </div>

          <div class="repeatable-shell" data-repeatable-list-root>
            <div class="repeatable-shell-head">
              <p class="section-kicker">Block catheters</p>
              <button type="button" class="button-link button-link-secondary" data-repeatable-add data-repeatable-target="block-catheter-list">Add catheter</button>
            </div>
            <div
              class="repeatable-list"
              id="block-catheter-list"
              data-repeatable-list
              data-repeatable-label="Block catheter name"
              data-repeatable-input-name="blockCatheterNames"
              data-repeatable-placeholder="e.g. Continuous femoral catheter"
            >
              <div class="repeatable-row">
                <label>
                  <span>Block catheter name</span>
                  <input type="text" name="blockCatheterNames" placeholder="e.g. Continuous femoral catheter" />
                </label>
                <button type="button" class="button-link button-link-secondary repeatable-remove" data-repeatable-remove>Remove</button>
              </div>
            </div>
          </div>

          <div class="repeatable-shell" data-repeatable-list-root>
            <div class="repeatable-shell-head">
              <p class="section-kicker">Single shot blocks</p>
              <button type="button" class="button-link button-link-secondary" data-repeatable-add data-repeatable-target="single-shot-list">Add block</button>
            </div>
            <div
              class="repeatable-list"
              id="single-shot-list"
              data-repeatable-list
              data-repeatable-label="Single shot block name"
              data-repeatable-input-name="singleShotBlockNames"
              data-repeatable-placeholder="e.g. TAP block"
            >
              <div class="repeatable-row">
                <label>
                  <span>Single shot block name</span>
                  <input type="text" name="singleShotBlockNames" placeholder="e.g. TAP block" />
                </label>
                <button type="button" class="button-link button-link-secondary repeatable-remove" data-repeatable-remove>Remove</button>
              </div>
            </div>
          </div>

          <label><span>Intra operative events</span><textarea name="intraoperativeEvents" rows="4" placeholder="Free text for significant events, problems, or important intraoperative issues."></textarea></label>

          <div class="checkbox-section">
            <p class="section-kicker">Post operative care</p>
            <div class="checkbox-grid">
              <% entryOptions.postOperativeCareOptions.forEach((option) => { %>
                <label class="checkbox-card">
                  <input type="checkbox" name="postOperativeCare" value="<%= option %>" />
                  <span><%= option %></span>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
      </fieldset>

      <fieldset class="form-section-card">
        <legend>Learning points</legend>
        <div class="fieldset-body">
          <div class="callout callout-info compact-callout">
            <p class="section-copy">At least one short learning point is mandatory for every saved case so the logbook captures what was learned, not only what was done.</p>
          </div>
          <div class="repeatable-shell" data-repeatable-list-root>
            <div class="repeatable-shell-head">
              <p class="section-kicker">Bullet entries</p>
              <button type="button" class="button-link button-link-secondary" data-repeatable-add data-repeatable-target="learning-point-list">Add point</button>
            </div>
            <div
              class="repeatable-list"
              id="learning-point-list"
              data-repeatable-list
              data-repeatable-label="Learning point"
              data-repeatable-input-name="learningPoints"
              data-repeatable-placeholder="Short bullet entry"
              data-repeatable-required="true"
            >
              <div class="repeatable-row">
                <label>
                  <span>Learning point 1</span>
                  <input type="text" name="learningPoints" required placeholder="Short bullet entry" />
                </label>
                <button type="button" class="button-link button-link-secondary repeatable-remove" data-repeatable-remove>Remove</button>
              </div>
            </div>
          </div>
        </div>
      </fieldset>

      <div class="logbook-form-actions">
        <button type="submit">Save logbook entry</button>
      </div>
    </form>
  </section>

  <section class="logbook-tab-panel" data-logbook-panel="analysis">
    <div class="section-header">
      <div>
        <p class="section-kicker">My analysis</p>
        <h2>Personal period summary</h2>
      </div>
      <a class="button-link button-link-secondary" href="<%= personal.printHref %>" target="_blank" rel="noreferrer">Print summary</a>
    </div>
    <form action="/logbook" method="get" class="inline-form compact-form filter-bar">
      <label><span>Start</span><input type="date" name="periodStart" value="<%= personal.range.start %>" required /></label>
      <label><span>End</span><input type="date" name="periodEnd" value="<%= personal.range.end %>" required /></label>
      <button type="submit">Refresh analysis</button>
    </form>

    <div class="stat-grid logbook-stat-grid">
      <article class="stat-card">
        <span>Total cases</span>
        <strong><%= personal.summary.totalCases %></strong>
      </article>
      <article class="stat-card">
        <span>Direct performance</span>
        <strong><%= personal.summary.directCareCases %></strong>
      </article>
      <article class="stat-card">
        <span>Clinical domains</span>
        <strong><%= personal.summary.domainCoverage %></strong>
      </article>
      <article class="stat-card">
        <span>Flagged events</span>
        <strong><%= personal.summary.complicationCount %></strong>
      </article>
    </div>

    <div class="callout">
      <p class="section-kicker">Narrative analysis</p>
      <p class="section-copy"><%= personal.summary.analysisNarrative %></p>
    </div>

    <div class="progression-board">
      <article class="progression-card">
        <span class="status-pill status-approved"><%= pretty(personal.summary.progression.stage) %> progression</span>
        <h3>Training signal</h3>
        <p class="section-copy">
          Direct care ratio: <strong><%= personal.summary.progression.directCareRatio %>%</strong> ·
          Emergency cases: <strong><%= personal.summary.progression.emergencyCases %></strong> ·
          Complex cases: <strong><%= personal.summary.progression.complexCases %></strong>
        </p>
      </article>
      <article class="progression-card">
        <h3>Strengths showing</h3>
        <% if (!personal.summary.progression.strengths.length) { %>
          <p class="meta-text">More logged work is needed before strengths can be inferred confidently.</p>
        <% } %>
        <% personal.summary.progression.strengths.forEach((item) => { %>
          <p class="signal-line signal-line-positive"><%= item %></p>
        <% }) %>
      </article>
      <article class="progression-card">
        <h3>Watch points</h3>
        <% if (!personal.summary.progression.watchPoints.length) { %>
          <p class="signal-line signal-line-neutral">No major watch points surfaced for this period.</p>
        <% } %>
        <% personal.summary.progression.watchPoints.forEach((item) => { %>
          <p class="signal-line signal-line-warning"><%= item %></p>
        <% }) %>
      </article>
    </div>

    <div class="metrics-board">
      <article class="metric-cluster">
        <h3>Domain mix</h3>
        <% if (!personal.summary.domainMix.length) { %>
          <p class="meta-text">No entries in the selected period yet.</p>
        <% } %>
        <% personal.summary.domainMix.forEach((item) => { %>
          <div class="metric-row"><span><%= pretty(item.label) %></span><strong><%= item.count %></strong></div>
        <% }) %>
      </article>
      <article class="metric-cluster">
        <h3>Procedure category mix</h3>
        <% personal.summary.procedureCategoryMix.forEach((item) => { %>
          <div class="metric-row"><span><%= pretty(item.label) %></span><strong><%= item.count %></strong></div>
        <% }) %>
      </article>
      <article class="metric-cluster">
        <h3>Supervision mix</h3>
        <% personal.summary.supervisionMix.forEach((item) => { %>
          <div class="metric-row"><span><%= pretty(item.label) %></span><strong><%= item.count %></strong></div>
        <% }) %>
      </article>
    </div>

    <div class="callout">
      <p class="section-kicker">Weekly report submission</p>
      <form action="/reviews/submit" method="post" class="inline-form compact-form filter-bar weekly-report-form">
        <label><span>Week start</span><input type="date" name="weekStartDate" required value="<%= personal.weeklySuggestion.start %>" /></label>
        <label><span>Week end</span><input type="date" name="weekEndDate" required value="<%= personal.weeklySuggestion.end %>" /></label>
        <button type="submit">Submit weekly report</button>
        <a class="button-link button-link-secondary" href="/logbook/print?mode=personal&periodStart=<%= personal.weeklySuggestion.start %>&periodEnd=<%= personal.weeklySuggestion.end %>" target="_blank" rel="noreferrer">Print this week</a>
      </form>
    </div>
  </section>

  <section class="logbook-tab-panel" data-logbook-panel="entries">
    <div class="section-header">
      <div>
        <p class="section-kicker">Case browser</p>
        <h2>Browse your structured case record</h2>
      </div>
    </div>
    <div class="logbook-browser-shell">
      <div class="logbook-browser-hero">
        <div>
          <p class="section-kicker">Personal record</p>
          <h3>Search, filter, and expand your case story</h3>
          <p class="section-copy">
            Showing entries from <strong><%= personal.range.start %></strong> to <strong><%= personal.range.end %></strong>. Change the analysis dates to widen or narrow the browser window.
          </p>
        </div>
        <div class="logbook-browser-stat-ribbon">
          <article class="logbook-browser-stat"><span>Shown</span><strong><%= personal.browseSummary.visibleCases %></strong></article>
          <article class="logbook-browser-stat"><span>Emergency</span><strong><%= personal.browseSummary.emergencyCases %></strong></article>
          <article class="logbook-browser-stat"><span>Complex</span><strong><%= personal.browseSummary.complexCases %></strong></article>
          <article class="logbook-browser-stat"><span>Flagged</span><strong><%= personal.browseSummary.flaggedCases %></strong></article>
        </div>
      </div>
      <form action="/logbook" method="get" class="logbook-browser-filter-bar">
        <input type="hidden" name="periodStart" value="<%= personal.range.start %>" />
        <input type="hidden" name="periodEnd" value="<%= personal.range.end %>" />
        <% if (canReview || canViewInvolvedCases) { %>
          <input type="hidden" name="teamView" value="<%= team.view %>" />
          <input type="hidden" name="memberId" value="<%= team.selectedMemberId %>" />
          <input type="hidden" name="memberPeriodStart" value="<%= team.range.start %>" />
          <input type="hidden" name="memberPeriodEnd" value="<%= team.range.end %>" />
        <% } %>
        <label><span>Search</span><input type="search" name="entrySearch" value="<%= personal.browseFilters.searchText %>" placeholder="Surgery, OT, case #, airway..." /></label>
        <label>
          <span>Case type</span>
          <select name="entryCaseType">
            <option value="">All case types</option>
            <% entryOptions.caseTypes.forEach((option) => { %>
              <option value="<%= option %>" <%= personal.browseFilters.caseType === option ? "selected" : "" %>><%= option %></option>
            <% }) %>
          </select>
        </label>
        <label>
          <span>Department</span>
          <select name="entryDepartment">
            <option value="">All departments</option>
            <% entryOptions.surgicalDepartments.forEach((option) => { %>
              <option value="<%= option %>" <%= personal.browseFilters.surgicalDepartment === option ? "selected" : "" %>><%= option %></option>
            <% }) %>
          </select>
        </label>
        <label class="logbook-browser-toggle">
          <input type="checkbox" name="entryFlagged" value="true" <%= personal.browseFilters.flaggedOnly ? "checked" : "" %> />
          <span>Flagged only</span>
        </label>
        <button type="submit">Browse cases</button>
        <a class="button-link button-link-secondary" href="/logbook?periodStart=<%= personal.range.start %>&periodEnd=<%= personal.range.end %>">Clear filters</a>
      </form>
    </div>
    <% if (!personal.entries.length) { %>
      <div class="empty-state">No logbook entries match this browser view yet.</div>
    <% } %>
    <div class="logbook-browser-results">
      <% personal.entries.forEach((entry) => { %>
        <article class="list-card logbook-entry-card">
          <div class="logbook-entry-head">
            <div>
              <p class="section-kicker"><%= caseLabel(entry) %></p>
              <strong><%= entry.procedureName %></strong>
            </div>
            <div class="tag-row">
