      <% } %>

      <% if (team.view === "overview" && team.overviewSnapshot) { %>
        <div class="stat-grid logbook-stat-grid">
          <article class="stat-card">
            <span>Members in unit</span>
            <strong><%= team.overviewSnapshot.totalMembers %></strong>
          </article>
          <article class="stat-card">
            <span>Members with cases</span>
            <strong><%= team.overviewSnapshot.membersWithCases %></strong>
          </article>
          <article class="stat-card">
            <span>Total cases in period</span>
            <strong><%= team.overviewSnapshot.totalCases %></strong>
          </article>
          <article class="stat-card">
            <span>Average cases per member</span>
            <strong><%= team.overviewSnapshot.averageCases %></strong>
          </article>
        </div>

        <div class="callout">
          <p class="section-kicker">Overview board</p>
          <p class="section-copy">
            This comparison board helps chief and faculty scan volume, breadth, complexity, and watch-point signals across the unit for one shared reporting window.
          </p>
        </div>

        <section class="overview-board">
          <% team.overviewMembers.forEach((member) => { %>
            <article class="overview-card">
              <div class="overview-card-top">
                <div>
                  <strong><%= member.userName %></strong>
                  <p class="meta-text"><%= member.designation %> · <%= member.roleLabel %></p>
                </div>
                <span class="status-pill status-approved"><%= pretty(member.stage) %></span>
              </div>
              <div class="overview-metrics">
                <div class="overview-metric"><span>Cases</span><strong><%= member.totalCases %></strong></div>
                <div class="overview-metric"><span>Direct care</span><strong><%= member.directCareRatio %>%</strong></div>
                <div class="overview-metric"><span>Domains</span><strong><%= member.domainCoverage %></strong></div>
                <div class="overview-metric"><span>Complex</span><strong><%= member.complexCases %></strong></div>
                <div class="overview-metric"><span>Emergency</span><strong><%= member.emergencyCases %></strong></div>
                <div class="overview-metric"><span>Flags</span><strong><%= member.flaggedEvents %></strong></div>
              </div>
              <p class="meta-text">Top domain: <%= member.topDomain %></p>
            </article>
          <% }) %>
        </section>

        <section class="logbook-browser-shell">
          <div class="logbook-browser-hero">
            <div>
              <p class="section-kicker">Unit-wide case browser</p>
              <h3>Scan cases across the whole unit</h3>
              <p class="section-copy">
                Built for chiefs and faculty to quickly identify volume, complexity, emergency exposure, and flagged events across learners.
              </p>
            </div>
            <div class="logbook-browser-stat-ribbon">
              <article class="logbook-browser-stat"><span>Shown</span><strong><%= team.unitBrowseSummary.visibleCases %></strong></article>
              <article class="logbook-browser-stat"><span>People</span><strong><%= team.unitBrowseSummary.peopleVisible %></strong></article>
              <article class="logbook-browser-stat"><span>Complex</span><strong><%= team.unitBrowseSummary.complexCases %></strong></article>
              <article class="logbook-browser-stat"><span>Flagged</span><strong><%= team.unitBrowseSummary.flaggedCases %></strong></article>
            </div>
          </div>
          <form action="/logbook" method="get" class="logbook-browser-filter-bar">
            <input type="hidden" name="periodStart" value="<%= personal.range.start %>" />
            <input type="hidden" name="periodEnd" value="<%= personal.range.end %>" />
            <input type="hidden" name="entrySearch" value="<%= personal.browseFilters.searchText %>" />
            <input type="hidden" name="entryCaseType" value="<%= personal.browseFilters.caseType %>" />
            <input type="hidden" name="entryDepartment" value="<%= personal.browseFilters.surgicalDepartment %>" />
            <% if (personal.browseFilters.flaggedOnly) { %>
              <input type="hidden" name="entryFlagged" value="true" />
            <% } %>
            <input type="hidden" name="teamView" value="overview" />
            <input type="hidden" name="memberPeriodStart" value="<%= team.range.start %>" />
            <input type="hidden" name="memberPeriodEnd" value="<%= team.range.end %>" />
            <label><span>Search</span><input type="search" name="teamEntrySearch" value="<%= team.browseFilters.searchText %>" placeholder="Learner, surgery, OT, case #..." /></label>
            <label>
              <span>Case type</span>
              <select name="teamEntryCaseType">
                <option value="">All case types</option>
                <% entryOptions.caseTypes.forEach((option) => { %>
                  <option value="<%= option %>" <%= team.browseFilters.caseType === option ? "selected" : "" %>><%= option %></option>
                <% }) %>
              </select>
            </label>
            <label>
              <span>Department</span>
              <select name="teamEntryDepartment">
                <option value="">All departments</option>
                <% entryOptions.surgicalDepartments.forEach((option) => { %>
                  <option value="<%= option %>" <%= team.browseFilters.surgicalDepartment === option ? "selected" : "" %>><%= option %></option>
                <% }) %>
              </select>
            </label>
            <label class="logbook-browser-toggle">
              <input type="checkbox" name="teamEntryFlagged" value="true" <%= team.browseFilters.flaggedOnly ? "checked" : "" %> />
              <span>Flagged only</span>
            </label>
            <button type="submit">Browse unit cases</button>
          </form>
          <% if (!team.unitBrowseEntries.length) { %>
            <div class="empty-state">No unit cases match the current browser filters.</div>
          <% } %>
          <div class="logbook-browser-results compact-browser-results">
            <% team.unitBrowseEntries.forEach((entry) => { %>
              <article class="logbook-browser-unit-card">
                <div class="logbook-entry-head">
                  <div>
                    <p class="section-kicker"><%= entry.userName %> <%= entry.designation ? `| ${entry.designation}` : "" %></p>
                    <strong><%= caseLabel(entry) %> | <%= entry.procedureName %></strong>
                  </div>
                  <div class="tag-row">
                    <span class="pill"><%= entry.activityDate %></span>
                    <span class="pill"><%= entry.caseType %></span>
                    <span class="pill"><%= pretty(entry.roleKey) %></span>
                  </div>
                </div>
                <div class="logbook-card-actions">
                <button
                  type="button"
                  class="button-link button-link-secondary logbook-view-case-button"
                  data-logbook-case-view
                  data-case-owner="<%= entry.userName %><%= entry.designation ? ` | ${entry.designation}` : '' %>"
                  data-case-number="<%= caseLabel(entry) %>"
                  data-case-title="<%= entry.procedureName %>"
                  data-case-date="<%= entry.activityDate %>"
                  data-case-type="<%= entry.caseType %>"
                  data-case-department="<%= showText(entry.surgicalDepartment) %>"
                  data-case-ot="<%= showText(entry.otNumber) %>"
                  data-case-age="<%= showText(entry.ageYears) %>"
                  data-case-gender="<%= showText(entry.gender) %>"
                  data-case-asa="<%= formatAsa(entry.asaPhysicalStatus) %>"
                  data-case-bmi="<%= entry.bmi ?? '-' %>"
                  data-case-time="<%= showText(entry.surgeryStartTime) %> to <%= showText(entry.surgeryEndTime) %>"
                  data-case-duration="<%= entry.durationMinutes ? `${entry.durationMinutes} minutes` : '-' %>"
                  data-case-plan="<%= showText(entry.anaestheticPlanned || pretty(entry.anaesthesiaTechnique)) %>"
                  data-case-supervision="<%= showText(entry.supervisionLevel) %>"
                  data-case-airway="<%= showText(entry.airwayManagement) %>"
                  data-case-scopy="<%= showText(entry.scopyTechnique) %>"
                  data-case-postop="<%= joinItems(entry.postOperativeCare) %>"
                  data-case-comorbidities="<%= joinItems(entry.comorbidities) %>"
                  data-case-procedures="<%= joinItems(entry.procedures) %>"
                  data-case-analgesia="<%= joinItems(entry.analgesiaItems) %>"
                  data-case-events="<%= entry.hadComplication ? entry.complicationSummary : '-' %>"
                  data-case-learning="<%= joinItems(entry.learningPoints) %>"
                  data-case-members="<%= formatAdditionalMembers(entry.additionalMembers) %>"
                >View case</button>
                <a class="button-link button-link-secondary logbook-print-case-button" href="/logbook/print/case/<%= entry.id %>" target="_blank" rel="noreferrer">Print case</a>
                </div>
                <p class="meta-text"><%= showText(entry.surgicalDepartment) %> | <%= showText(entry.anaestheticPlanned || pretty(entry.anaesthesiaTechnique)) %> | <%= showText(entry.supervisionLevel) %></p>
                <p class="meta-text">OT <%= showText(entry.otNumber) %> | <%= formatAsa(entry.asaPhysicalStatus) %> | Post op: <%= joinItems(entry.postOperativeCare) %></p>
                <% if (entry.additionalMembers.length) { %>
                  <p class="meta-text">Additional members: <%= formatAdditionalMembers(entry.additionalMembers) %></p>
                <% } %>
                <% if (entry.hadComplication) { %>
                  <p class="status-callout status-returned">Intra operative events: <%= entry.complicationSummary %></p>
                <% } %>
                <% if (entry.learningPoints.length) { %>
                  <p class="meta-text">Learning: <%= joinItems(entry.learningPoints) %></p>
                <% } %>
              </article>
            <% }) %>
          </div>
        </section>

        <section class="panel panel-nested">
          <div class="section-header">
            <div>
              <p class="section-kicker">Comparison table</p>
              <h3>All trainees in one screen</h3>
            </div>
          </div>
          <div class="overview-table-shell">
            <div class="overview-table">
              <div class="overview-table-head">
                <span>Name</span>
                <span>Cases</span>
                <span>Direct care</span>
                <span>Domains</span>
                <span>Complex</span>
                <span>Emergency</span>
                <span>Flags</span>
                <span>Top domain</span>
              </div>
              <% team.overviewMembers.forEach((member) => { %>
                <article class="overview-table-row">
                  <span><strong><%= member.userName %></strong><small><%= member.roleLabel %></small></span>
                  <span><%= member.totalCases %></span>
                  <span><%= member.directCareRatio %>%</span>
                  <span><%= member.domainCoverage %></span>
                  <span><%= member.complexCases %></span>
                  <span><%= member.emergencyCases %></span>
                  <span><%= member.flaggedEvents %></span>
                  <span><%= member.topDomain %></span>
                </article>
              <% }) %>
            </div>
          </div>
        </section>
      <% } %>
    </section>
  <% } %>
</section>

<div class="logbook-case-modal" data-logbook-case-modal hidden>
  <div class="logbook-case-modal-backdrop" data-logbook-case-modal-close></div>
  <section class="logbook-case-modal-card" role="dialog" aria-modal="true" aria-labelledby="logbook-case-modal-title">
    <div class="logbook-case-modal-hero">
      <div>
        <p class="section-kicker" data-case-modal-owner>Case owner</p>
        <h2 id="logbook-case-modal-title" data-case-modal-title>Case detail</h2>
        <div class="tag-row">
          <span class="pill" data-case-modal-number>Case</span>
          <span class="pill" data-case-modal-date>Date</span>
          <span class="pill" data-case-modal-type>Type</span>
        </div>
      </div>
      <button type="button" class="button-link button-link-secondary" data-logbook-case-modal-close>Close</button>
    </div>

    <div class="logbook-case-modal-body">
      <section class="logbook-case-modal-section">
        <p class="section-kicker">Case identity</p>
        <div class="logbook-case-modal-grid">
          <article><span>Department</span><strong data-case-modal-department>-</strong></article>
          <article><span>OT number</span><strong data-case-modal-ot>-</strong></article>
          <article><span>Timing</span><strong data-case-modal-time>-</strong></article>
          <article><span>Duration</span><strong data-case-modal-duration>-</strong></article>
        </div>
      </section>

      <section class="logbook-case-modal-section">
        <p class="section-kicker">Patient and anaesthesia context</p>
        <div class="logbook-case-modal-grid">
          <article><span>Demographics</span><strong><span data-case-modal-age>-</span> y | <span data-case-modal-gender>-</span></strong></article>
          <article><span>ASA / BMI</span><strong><span data-case-modal-asa>-</span> | BMI <span data-case-modal-bmi>-</span></strong></article>
          <article><span>Anaesthetic plan</span><strong data-case-modal-plan>-</strong></article>
          <article><span>Supervision</span><strong data-case-modal-supervision>-</strong></article>
          <article><span>Airway</span><strong data-case-modal-airway>-</strong></article>
          <article><span>Scopy</span><strong data-case-modal-scopy>-</strong></article>
        </div>
      </section>

      <section class="logbook-case-modal-section">
        <p class="section-kicker">Procedures and outcome</p>
        <div class="logbook-case-modal-notes">
          <article><span>Additional members</span><p data-case-modal-members>-</p></article>
          <article><span>Comorbidities</span><p data-case-modal-comorbidities>-</p></article>
          <article><span>Procedures</span><p data-case-modal-procedures>-</p></article>
          <article><span>Analgesia</span><p data-case-modal-analgesia>-</p></article>
          <article><span>Post operative care</span><p data-case-modal-postop>-</p></article>
          <article><span>Intra operative events</span><p data-case-modal-events>-</p></article>
        </div>
      </section>

      <section class="logbook-case-modal-section learning-section">
        <p class="section-kicker">Learning points</p>
        <p data-case-modal-learning>-</p>
      </section>
    </div>
  </section>
</div>

<%- include("../partials/footer") %>
